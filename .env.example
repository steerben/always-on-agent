# --- Claude / model ---
ANTHROPIC_API_KEY=sk-ant-...
AGENT_MODEL=claude-opus-4-7

# --- Where the synthetic enterprise data lives ---
# Defaults to the repo root (parent of the agent/ package).
REPO_DIR=

# --- Side effects ---
# DRY_RUN=true: the PR and Slack tools log what they WOULD do and make no changes.
# Set to false only once GITHUB_REPO + Slack are wired up and you want real PRs.
DRY_RUN=true

# GitHub repo the PR is opened against (owner/name). Used by `gh`.
GITHUB_REPO=steerben/always-on-agent
# Base branch the PR targets.
PR_BASE_BRANCH=main

# Slack incoming-webhook URL for notifications.
SLACK_WEBHOOK_URL=

# --- Webhook trigger auth ---
# Shared secret required in the X-Agent-Secret header on POST /trigger.
WEBHOOK_SECRET=change-me
